# Copia este archivo a .env y ajusta los valores

# Conexión a PostgreSQL
DATABASE_URL=postgres://usuario:password@localhost:5432/tablero

# Puerto del servidor
PORT=4000

# Origen permitido para CORS (el dominio de tu front). Usa * solo en desarrollo.
CORS_ORIGIN=https://www.creativostecnologicosit.com

# Secreto para firmar los JWT (usa una cadena larga y aleatoria en producción)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=8h

# Super admin inicial (usado por  npm run seed:admin)
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@creativostecnologicosit.com
ADMIN_PASSWORD=cambia-esta-clave
