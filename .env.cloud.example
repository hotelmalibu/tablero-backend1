# =====================================================================
#  Variables de entorno para despliegue en la NUBE (Render / Railway)
#  con PostgreSQL gestionado (Neon, Render Postgres, Supabase…).
#  NO subas este archivo con valores reales al repositorio.
#  En Render/Railway estas variables se cargan en el panel, no en un archivo.
# =====================================================================

# Cadena de conexión de tu base en la nube. Neon la entrega ya con ?sslmode=require
DATABASE_URL=postgres://usuario:password@ep-xxx.us-east-2.aws.neon.tech/tablero?sslmode=require

# Fuerza SSL aunque la cadena no lo indique (opcional; ya se autodetecta para Neon/Render)
PGSSL=true

# El proveedor asigna el puerto automáticamente; no lo fijes en la nube.
# PORT=4000

# Dominio EXACTO del frontend (el sitio en tu cPanel), con https:// y sin barra final
CORS_ORIGIN=https://www.creativostecnologicosit.com

# Secreto para firmar los JWT (usa una cadena larga y aleatoria; en Render se autogenera)
JWT_SECRET=pon-aqui-una-cadena-larga-y-aleatoria-de-al-menos-40-caracteres
JWT_EXPIRES_IN=8h

# Super admin inicial (se crea con  npm run seed:admin)
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@creativostecnologicosit.com
ADMIN_PASSWORD=pon-una-contrasena-fuerte
